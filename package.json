{
  "name": "memorix",
  "version": "2.1.0",
  "description": "AI Long-Term Memory System with SQLite FTS5",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "dev": "node src/server.js",
    "view": "node scripts/view-db.js",
    "test": "node --test",
    "clawhub:preflight": "bash ./scripts/clawhub_preflight.sh",
    "clawhub:security": "bash ./scripts/clawhub_run_security_cases.sh",
    "clawhub:verify": "npm run clawhub:preflight && npm run clawhub:security",
    "clawhub:publish": "bash ./scripts/clawhub_publish_safe.sh",
    "skillsmp:readiness": "bash ./scripts/skillsmp_readiness.sh",
    "skillsmp:probe": "bash ./scripts/skillsmp_probe.sh",
    "openclaw:install": "bash ./scripts/openclaw_install_workspace_skill.sh",
    "openclaw:materialize": "bash ./scripts/openclaw_materialize_skill_package.sh",
    "openclaw:mcp-snippet": "bash ./scripts/openclaw_emit_mcp_snippet.sh",
    "openclaw:allowlists": "bash ./scripts/openclaw_emit_allowlists.sh",
    "upgrade:preflight": "bash ./scripts/upgrade/preflight.sh",
    "upgrade:doctor": "bash ./scripts/upgrade/doctor.sh",
    "upgrade:backup": "bash ./scripts/upgrade/backup.sh",
    "upgrade:rollback": "bash ./scripts/upgrade/rollback.sh"
  },
  "keywords": [
    "openclaw",
    "context-compaction",
    "long-session",
    "agent-memory",
    "governance",
    "mcp",
    "memory",
    "fts5",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moyage/memorix.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
