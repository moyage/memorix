#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo -e "${GREEN}[agent-laws]${NC} checking schema-first compliance"

SCHEMA_DIR="docs/L2_Protocol_Schema"
ADR_DIR="docs/ADR"

HEAVY_FRAMEWORKS="express|fastify|koa|hapi|@nestjs|react|vue|angular|svelte|@chroma|chromadb|pgvector|pinecone|weaviate|qdrant|langchain|@langchain|motorhead|redis|ioredis|mongoose|prisma|typeorm|sequelize"

SCHEMA_CHANGED=$(git diff --cached --name-only | grep "^$SCHEMA_DIR/" || true)

if [ -n "$SCHEMA_CHANGED" ]; then
  echo -e "${YELLOW}[agent-laws]${NC} Schema files changed:"
  echo "$SCHEMA_CHANGED" | while read -r f; do
    echo "  - $f"
  done
  
  ADR_CHANGED=$(git diff --cached --name-only | grep "^$ADR_DIR/" || true)
  
  if [ -z "$ADR_CHANGED" ]; then
    echo -e "${RED}ERROR: Schema changes detected without ADR${NC}"
    echo "Law 3: Anti-Drift Law requires ADR for schema changes"
    echo ""
    echo "Please create an ADR in $ADR_DIR/ that justifies the schema change"
    exit 1
  fi
  
  echo -e "${GREEN}[agent-laws]${NC} ADR present for schema changes"
fi

detect_heavy_frameworks() {
  local files=$(git diff --cached --name-only | grep -E '\.(js|ts|jsx|tsx|mjs|cjs)$' || true)
  local detected=""
  
  for file in $files; do
    if [ -f "$file" ]; then
      content=$(git show ":$file" 2>/dev/null || echo "")
      for fw in $(echo "$HEAVY_FRAMEWORKS" | tr '|' ' '); do
        if echo "$content" | grep -qE "(import|require).*['\"]$fw"; then
          detected="$detected $fw"
        fi
      done
    fi
  done
  
  echo "$detected"
}

FRAMEWORKS_DETECTED=$(detect_heavy_frameworks)
if [ -n "$FRAMEWORKS_DETECTED" ]; then
  echo -e "${RED}ERROR: Heavy frameworks detected${NC}"
  echo "Law 4: Complexity Budget exceeded"
  echo ""
  echo -e "${YELLOW}Detected frameworks:$FRAMEWORKS_DETECTED${NC}"
  echo ""
  echo "Introduction of heavy frameworks (web, DB, UI) requires:"
  echo "  1. An ADR in $ADR_DIR/ justifying the choice"
  echo "  2. Hermes cross-review and approval"
  echo ""
  echo "HALT: Commit blocked - complexity budget exceeded"
  exit 1
fi

NEW_SCHEMA_FILES=$(git diff --cached --name-only | grep "^$SCHEMA_DIR/" | grep -E '\.(json|yaml|yml|ts|js)$' || true)
if [ -n "$NEW_SCHEMA_FILES" ]; then
  echo -e "${GREEN}[agent-laws]${NC} New schema files detected - ensuring format validity"
fi

echo -e "${GREEN}[agent-laws]${NC} Schema-first compliance check passed"
